# Google AI / Vertex AI
GOOGLE_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
# Set to True for Vertex AI, omit or False for Google AI
GOOGLE_GENAI_USE_VERTEXAI=False

# Firebase Admin
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
# Or path to service account JSON
GOOGLE_APPLICATION_CREDENTIALS=

# Cloud Storage
GCS_ARTIFACTS_BUCKET=olaf-artifacts

# Application
PORT=8080
ALLOWED_ORIGINS=http://localhost:3000
LOG_LEVEL=info

# Session persistence
SESSION_DB_URI=sqlite+aiosqlite:///./sessions.db

# ADK Dev UI (set true to enable at /dev-ui)
ENABLE_DEV_UI=false
