rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isFamilyOf(elderlyUserId) {
      return isAuthenticated()
        && request.auth.token.role == "family"
        && elderlyUserId in request.auth.token.linked_elderly_users;
    }

    function isOwnerOrFamily(userId) {
      return isOwner(userId) || isFamilyOf(userId);
    }

    // ── User profiles ─────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwnerOrFamily(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // Never allow profile deletion
    }

    // ── Health logs ──────────────────────────────────────────────────
    match /users/{userId}/healthLogs/{logId} {
      allow read: if isOwnerOrFamily(userId);
      allow create: if isOwner(userId) || isFamilyOf(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // ── Conversations ────────────────────────────────────────────────
    match /users/{userId}/conversations/{convId} {
      allow read: if isOwnerOrFamily(userId);
      allow create: if isOwner(userId);
      allow update: if false;
      allow delete: if false;
    }

    // ── Memory chapters ──────────────────────────────────────────────
    match /users/{userId}/memories/{memoryId} {
      allow read: if isOwnerOrFamily(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // Memories are permanent
    }

    // ── Alerts ───────────────────────────────────────────────────────
    match /users/{userId}/alerts/{alertId} {
      allow read: if isOwnerOrFamily(userId);
      allow create: if isOwner(userId); // Created by backend on behalf of user
      allow update: if isFamilyOf(userId); // Family acknowledges alerts
      allow delete: if false;
    }

    // ── Reports ──────────────────────────────────────────────────────
    match /users/{userId}/reports/{reportId} {
      allow read: if isOwnerOrFamily(userId);
      allow create: if isOwner(userId);
      allow update: if false;
      allow delete: if false;
    }

    // ── Reminders ────────────────────────────────────────────────────
    match /users/{userId}/reminders/{reminderId} {
      allow read: if isOwnerOrFamily(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // ── FCM tokens ───────────────────────────────────────────────────
    match /users/{userId}/fcmTokens/{tokenId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // ── Family links (legacy — prefer custom claims) ─────────────────
    match /familyLinks/{linkId} {
      allow read: if isAuthenticated()
        && (resource.data.familyUserId == request.auth.uid
            || resource.data.elderlyUserId == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if isAuthenticated()
        && resource.data.familyUserId == request.auth.uid;
    }

    // ── Default deny ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
